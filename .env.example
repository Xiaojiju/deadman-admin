# 复制为 .env 或在 IDE / 部署环境中配置（勿提交真实密钥到 Git）

DB_HOST=localhost
DB_PORT=3306
DB_NAME=deadman_admin
DB_USERNAME=root
DB_PASSWORD=your_db_password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 至少 32 字符
DEADMAN_JWT_SECRET=your-jwt-secret-at-least-32-characters-long
DEADMAN_JWT_EXPIRATION_MS=86400000
DEADMAN_USER_CODE_PREFIX=DM

# 用户端组件（独立 JWT 与用户表，路径前缀 /client/api）
DEADMAN_COMPONENT_CLIENT_ENABLED=true
DEADMAN_CLIENT_JWT_SECRET=your-client-jwt-secret-at-least-32-characters-long
DEADMAN_CLIENT_JWT_EXPIRATION_MS=604800000
DEADMAN_CLIENT_USER_CODE_PREFIX=CL
DEADMAN_CLIENT_MULTI_SESSION_ENABLED=true

# 微信小程序插件
DEADMAN_PLUGIN_WECHAT_MINIPROGRAM_ENABLED=true
DEADMAN_WECHAT_MINIPROGRAM_APP_ID=your-wechat-miniprogram-app-id
DEADMAN_WECHAT_MINIPROGRAM_APP_SECRET=your-wechat-miniprogram-app-secret

# 管理端微信桥接（support 模块，仅 admin 组）
DEADMAN_SUPPORT_WECHAT_ENABLED=true
DEADMAN_SUPPORT_WECHAT_BIND_TOKEN_TTL=10m

# 启动引导：系统中无 SUPER_ADMIN 时自动创建/绑定管理员（生产务必修改密码）
DEADMAN_BOOTSTRAP_ADMIN_ENABLED=true
DEADMAN_SUPER_ADMIN_USERNAME=admin
DEADMAN_SUPER_ADMIN_PASSWORD=change-me-at-least-8-chars
DEADMAN_SUPER_ADMIN_NICKNAME=系统管理员
